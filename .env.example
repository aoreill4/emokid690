# TikTok session token, improves TikTokApi reliability and reduces bot-blocking.
# How to get it: log in to tiktok.com in a browser as @emokid690, open DevTools,
# Application -> Cookies -> https://www.tiktok.com, copy the value of "msToken".
# Leave blank to try an anonymous session (works sometimes, blocks more often).
MS_TOKEN=

# Optional proxy pool to spread requests across IPs (reduces rate-limits/blocks).
# Comma- and/or newline-separated list of proxy URLs. Each request pool is spread
# across them and the lead proxy rotates on recycle. Leave blank for direct
# connections (default). Supports http/https/socks5, with optional credentials:
#   TIKTOK_PROXIES=http://user:pass@proxy1.example.com:8000,http://user:pass@proxy2.example.com:8000
# Residential/rotating proxies work best; datacenter IPs are blocked more often.
# (You can also pass proxies ad hoc on the CLI with repeated --proxy flags.)
TIKTOK_PROXIES=
